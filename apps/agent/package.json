{
  "name": "@relaydesk/windows-agent",
  "version": "0.1.9",
  "description": "RelayDesk local Windows executor for reliable WhatsApp account synchronization",
  "author": "RelayDesk",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "test:store": "npm run build && node --test test/store.test.mjs",
    "test:preload": "npm run build && electron scripts/preload-smoke-main.mjs",
    "start": "electron .",
    "package:win": "npm run build && electron-builder --win nsis --x64 --publish never"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "6.7.23",
    "https-proxy-agent": "7.0.6",
    "pino": "9.7.0",
    "qrcode": "1.5.4",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@types/node": "22.15.30",
    "@types/qrcode": "1.5.6",
    "@types/ws": "8.18.1",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "typescript": "5.8.3"
  },
  "build": {
    "appId": "com.relaydesk.agent",
    "productName": "RelayDesk Agent",
    "artifactName": "RelayDesk-Agent-${version}-${arch}.${ext}",
    "asar": true,
    "asarUnpack": [
      "dist/account-worker.js"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  }
}
